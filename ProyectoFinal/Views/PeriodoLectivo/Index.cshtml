@model IEnumerable<ProyectoFinalModel.PeriodoLectivo>

<p>
    @Html.ActionLink("Crear Periodo Lectivo", "Create")
</p>

<div class="content">
    <div class="row">
        <div class="col-md-12">
            <table id="example2" class="table table-striped table-bordered dt-responsive nowrap">
                <thead>
                    <tr>
                        <th>Id Periodo Lectivo</th>
                        <th>Descripcion</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#example2').DataTable().destroy();

        var arr = @Html.Raw(Json.Encode(Model));

        $('#example2').DataTable({
            "autoWidth": false,
            "info": false,
            //"serverSide": true,
            "JQueryUI": true,
            "ordering": true,
            "paging": true,
            //"scrollY": "500px",
            //"Select": true,
            "scrollCollapse": true,
            "responsive": true,
            "processing": true,
            //"data": data.data,
            "data": arr,
            "columns": [
                { "data": "IdPeriodoLectivo", "className": 'IdPeriodoLectivo', "title": "Id Periodo Lectivo" },
                { "data": "Descripcion", "className": 'Descripcion', "title": "Descripcion" },
                {
                    "data": "FechaInicio",
                    render: function (data, type, row) {
                        if (type === "sort" || type === "type") {
                            return data;
                        }
                        return moment(data).format("YYYY-MM-DD");
                    }
                },
                {
                    "data": "FechaFin",
                    render: function (data, type, row) {
                        if (type === "sort" || type === "type") {
                            return data;
                        }
                        return moment(data).format("YYYY-MM-DD");
                    }
                },
                { "data": "Estado", "className": 'Estado', "title": "Estado" },
                {
                    "render": function (data, type, row) {

                    var myUrl = '@Url.Action("Edit", "PeriodoLectivo")/' + row.IdPeriodoLectivo;
                    return '<a href=\"' + myUrl + '\" class=\"btn btn-default btn-sm\">Edit</a>';
                }
                },
            ],
        });
    });

</script>