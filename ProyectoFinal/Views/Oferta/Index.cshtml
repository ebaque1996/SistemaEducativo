        });

        $("#txtSelectDirigente").on("select2-selecting", function (e) { document.getElementById('txtDirigente').value = e.val; });

        $('#txtSelectDirigente').select2({
            width: '100%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Dirigente",

            ajax: {
                url: '/Oferta/GetProfesores',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

        $("#txtSelectJornada").on("select2-selecting", function (e) { document.getElementById('txtJornada').value = e.val; });

        $('#txtSelectJornada').select2({
            width: '100%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Jornada",

            ajax: {
                url: '/Oferta/GetJornadas',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

    });

    $('#txtSelectPeriodo').on("change", function (e) {
        if ($(txtSelectPeriodo).select2('data') != null) {
            $.ajax({
                type: "GET",
                url: "/Oferta/GetDetalle",
                data: { idPer: document.getElementById('txtPeriodo').value },
                dataType: "json",
                success: function (data) {
                    GeneraConsulta(data.listOfertaExt);
                }
            });
        } else {
            $('#example2').DataTable().clear().draw();
            document.getElementById('txtPeriodo').value = null;
        }
    });

    $('#txtSelectCurso').on("change", function (e) {
        if ($(txtSelectCurso).select2('data') == null) {
            document.getElementById('txtCurso').value = null;
        }
    });

    $('#txtSelectParalelo').on("change", function (e) {
        if ($(txtSelectParalelo).select2('data') == null) {
            document.getElementById('txtParalelo').value = null;
        }
    });

    $('#txtSelectDirigente').on("change", function (e) {
        if ($(txtSelectDirigente).select2('data') == null) {
            document.getElementById('txtDirigente').value = null;
        }
    });

    $('#txtSelectJornada').on("change", function (e) {
        if ($(txtSelectJornada).select2('data') == null) {
            document.getElementById('txtJornada').value = null;
        }
    });

    $('input[type=number]').blur(function () {
        var num = parseFloat($(this).val());
        var cleanNum = num;
        $(this).val(cleanNum);
    });

    $('#btnAddRow').on('click', function () {

        var IdPeriodo = document.getElementById("txtPeriodo").value;
        var IdCurso = document.getElementById("txtCurso").value;
        var IdParalelo = document.getElementById("txtParalelo").value;
        var IdProfesor = document.getElementById("txtDirigente").value;
        var Jornada = document.getElementById("txtJornada").value;
        var Capacidad = document.getElementById("txtCapacidad").value;

        if (document.getElementById("txtPeriodo").value == null || document.getElementById("txtPeriodo").value == '') { IdPeriodo = 0;}
        if (document.getElementById("txtCurso").value == null || document.getElementById("txtCurso").value == '') { IdCurso = 0; }
        if (document.getElementById("txtParalelo").value == null || document.getElementById("txtParalelo").value == '') {IdParalelo = 0;}
        if (document.getElementById("txtDirigente").value == null || document.getElementById("txtDirigente").value == '') {IdProfesor = 0;}
        if (document.getElementById("txtCapacidad").value == null || document.getElementById("txtCapacidad").value == '') {Capacidad = 0;}

        var jsonCad = "{'IdPeriodo':'" + IdPeriodo + "'";
        jsonCad = jsonCad + ", 'IdCurso': '" + IdCurso + "'";
        jsonCad = jsonCad + ", 'IdParalelo': '" + IdParalelo + "'";
        jsonCad = jsonCad + ", 'IdProfesor': '" + IdProfesor + "'";
        jsonCad = jsonCad + ", 'Jornada': '" + Jornada + "'";
        jsonCad = jsonCad + ", 'Capacidad': '" + Capacidad + "'";
        jsonCad = jsonCad + "}";

        swal({
            title: "Oferta ",
            text: "Desea grabar el registro? ",
            type: "info",
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true
        }, function (isConfirm) {
            if (isConfirm) {

                $.ajax(
                    {
                        type: "POST",
                        url: "/Oferta/Create",
                        data: jsonCad,
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (data) {

                            if (data.bResultado) {
                                swal("Saved", data.Message, "success");
                                GeneraConsulta(data.listOfertaExt);
                                limpiar();
                            }
                            else {
                                swal("Cancelled", data.Message, "error");
                            }
                        }
                    }
                )

            }

        });
    });

    function GeneraConsulta(listOfertaExt) {
        $('#example2').DataTable().destroy();

        $('#example2').DataTable({
            "autoWidth": false,
            "info": false,
            "JQueryUI": true,
            "ordering": false,
            "paging": false,
            "responsive": true,
            "processing": true,
            "data": listOfertaExt,
            "columns": [
                { "data": "IdOferta", "className": 'IdOferta', "title": "Id Oferta", "visible": false },
                { "data": "IdPeriodoLectivo", "className": 'IdPeriodoLectivo', "title": "Id Periodo Lectivo", "visible": false },
                { "data": "IdCurso", "className": 'IdCurso', "title": "Id Curso", "visible": false },
                { "data": "IdParalelo", "className": 'IdParalelo', "title": "Id Paralelo", "visible": false },
                { "data": "IdProfesor", "className": 'IdProfesor', "title": "Id Profesor", "visible": false },                
                { "data": "DescPerLec", "className": 'DescPerLec', "title": "Periodo Lectivo" },
                { "data": "DescCurso", "className": 'DescCurso', "title": "Curso" },
                { "data": "DescParalelo", "className": 'DescParalelo', "title": "Paralelo" },
                { "data": "DescProfesor", "className": 'DescProfesor', "title": "Dirigente" },
                { "data": "DescJornada", "className": 'DescJornada', "title": "Jornada" },
                { "data": "Capacidad", "className": 'Capacidad', "title": "Capacidad" },
                { "data": "Ocupado", "className": 'Ocupado', "title": "Ocupado" },
                { "data": "Disponible", "className": 'Disponible', "title": "Disponible" },
                { "data": "Estado", "className": 'Estado', "title": "Estado" },

                {
                    "data": "btnEdit", "className": 'btnEdit', "title": "", "width": "5%",
                    "render": function (data, type, row) {
                        var sCad = '<button type="button" class="btn btn-info btn-sm btnEditRow"> ';
                        sCad = sCad + '<i class="fa fas fa-edit" aria - hidden="true" ></i >';
                        sCad = sCad + '</button>';

                        return sCad;
                    }
                    //, orderable: false, "width": "5%"

                },

                //{
                //    "data": "btnElim", "className": 'btnElim', "title": "", "width": "5%",
                //    "render": function (data, type, row) {
                //        var sCad = '<button type="button" class="btn btn-danger btn-sm btnDeleteRow"> ';
                //        sCad = sCad + '<i class="fa fas fa-trash" aria - hidden="true" ></i >';
                //        sCad = sCad + '</button>';

                //        return sCad;
                //    }

                //}
            ],
        });
    }

    function limpiar() {
        $('#txtSelectCurso').select2('data', null);
        $('#txtSelectParalelo').select2('data', null);
        $('#txtSelectDirigente').select2('data', null);
        $('#txtSelectJornada').select2('data', null);
        document.getElementById('txtCurso').value = null;
        document.getElementById('txtParalelo').value = null;
        document.getElementById('txtDirigente').value = null;
        document.getElementById('txtJornada').value = null;
        $('#txtCapacidad').val("");
    }

    $('#example2').DataTable().on('click', '.btnEditRow', function () {
        var table = $('#example2').DataTable();
        var data = table.row($(this).parents('tr')).data();
        var rowIndexSelected;

        $.ajax({
            type: 'GET',
            url: "/Oferta/EditOferta",
            data: { IdOferta: data.IdOferta },
            dataType: 'html',

        }).done(function (response) {
            $('.table-placeholder2').html(response);
            $('#lista_productosModal').modal('show');
            limpiar();
        }
        ).fail(function () {
            alert("error");
        });

    });

    $("#lista_productosModal").on("hidden.bs.modal", function () {
        if ($(txtSelectPeriodo).select2('data') != null) {
            $.ajax({
                type: "GET",
                url: "/Oferta/GetDetalle",
                data: { idPer: document.getElementById('txtPeriodo').value },
                dataType: "json",
                success: function (data) {
                    GeneraConsulta(data.listOfertaExt);
                }
            });
        } else {
            $('#example2').DataTable().clear().draw();
        }
    });


