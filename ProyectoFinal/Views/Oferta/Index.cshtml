
<h2>Ofertas</h2>

<div class="content">
    <div class="row">
        <div class="box box-default">
            <div class="box-header with-border">
                <h3 class="box-title"> Parametros de Consulta </h3>
            </div>
            <div class="box-body">
                <div class="form-group">
                    <input type="text" id="txtSelectPeriodo" />
                    <input type="text" id="txtPeriodo" hidden />
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="box box-default">
            <div class="box-header with-border">
                <h3 class="box-title"> Detalle </h3>
            </div>
            <div class="box-body">

                <div class="box-body">

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label class="form-control no-border">Curso:</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="txtSelectCurso" />
                                    <input type="text" id="txtCurso" hidden />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label class="form-control no-border">Paralelo:</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="txtSelectParalelo" />
                                    <input type="text" id="txtParalelo" hidden />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label class="form-control no-border">Dirigente:</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="txtSelectDirigente" />
                                    <input type="text" id="txtDirigente" hidden />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label class="form-control no-border">Capacidad:</label>
                                </div>
                                <div class="col-md-8">
                                    @*<input type="text" class="form-control"
                        id="txtCapacidad" placeholder="Capacidad" />*@

                                    <input min="0" step="1" class="form-control" id="txtCapacidad" type="number" name="txtCapacidad" placeholder="Capacidad " />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label class="form-control no-border">Jornada:</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="txtSelectJornada" />
                                    <input type="text" id="txtJornada" hidden />
                                </div>
                            </div>
                        </div>                        
                    </div>

                    <br />

                    <div class="row">
                        <div class="col-md-12">
                            <input type="button" class="btn btn-primary" id="btnAddRow" value="Agregar" />
                        </div>
                    </div>

                </div>

                <br />

                <table id="example2" class="table table-striped table-bordered dt-responsive nowrap">
                    <thead>
                        <tr>
                            <th>Id Oferta</th>
                            <th>Id Periodo Lectivo</th>
                            <th>Id Curso</th>
                            <th>Id Paralelo</th>
                            <th>Id Dirigente</th>
                            <th>Periodo Lectivo</th>
                            <th>Curso</th>
                            <th>Paralelo</th>
                            <th>Dirigente</th>
                            <th>Jornada</th>
                            <th>Capacidad</th>
                            <th>Ocupado</th>
                            <th>Disponible</th>
                            <th>Estado</th>
                            <th></th>
                            @*<th></th>*@
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="lista_productosModal" tabindex="-1" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title"> Editar Oferta</h4>
            </div>
            <div class="modal-body table-placeholder2"></div>
        </div>
    </div>
</div>

<script>

    $(document).ready(function () {
        $("#txtSelectPeriodo").on("select2-selecting", function (e) { document.getElementById('txtPeriodo').value = e.val; });

        $('#txtSelectPeriodo').select2({
            width: '50%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Periodo Lectivo",

            ajax: {
                url: '/Oferta/GetPeriodos',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

        $("#txtSelectCurso").on("select2-selecting", function (e) { document.getElementById('txtCurso').value = e.val; });

        $('#txtSelectCurso').select2({
            width: '100%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Curso",

