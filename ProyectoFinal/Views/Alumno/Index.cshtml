@if (!Request.IsAuthenticated)
{
    Response.Redirect("~/Account/Login");
}

<p>
    @Html.ActionLink("Crear Alumno", "Create")
</p>

<div class="content">

    <div class="row">
        <div class="box box-default">
            <div class="box-header with-border">
                <h3 class="box-title"> Parámetros de Consulta </h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Cédula Alumno:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtCedAl" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Apellidos Alumno:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtApAl" style="text-transform:uppercase" />
                            </div>
                        </div>
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Nombres Alumno:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtNomAl" style="text-transform:uppercase" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Cédula Representante:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtCedRep" />
                            </div>
                        </div>
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Apellidos Representante:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtApRep" style="text-transform:uppercase" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Nombres Representante:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" class="form-control" id="txtNomRep" style="text-transform:uppercase" />
                            </div>
                        </div>
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label class="form-control no-border">Estado:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" id="txtSelectEstado" />
                                <input type="text" id="txtEstado" hidden />
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="box-footer with-border">
                <input type="button" class="btn btn-primary" id="btnConsultar" value="Consultar" />
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <table id="example2" class="table table-striped table-bordered dt-responsive nowrap">
                <thead>
                    <tr>
                        <th>Id Alumno</th>
                        <th>Cédula</th>
                        @*<th>Nombres</th>*@
                        <th>Apellidos</th>
                        <th>Nombres</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

