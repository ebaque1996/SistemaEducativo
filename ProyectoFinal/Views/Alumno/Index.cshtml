    $('#btnConsultar').on('click', function () { consultar(); });

    function consultar() {

        if (true) {
            $.ajax({
                type: "GET",
                url: "/Alumno/GetAlumnos",
                //data: { idperiodo: document.getElementById('txtPeriodo').value, idoferta: document.getElementById('txtCurso').value, idmateria: document.getElementById('txtMateria').value, idalumno: document.getElementById('txtAlumno').value, idestado: document.getElementById('txtEstado').value },
                data: { cedAl: document.getElementById('txtCedAl').value, apAl: document.getElementById('txtApAl').value, nomAl: document.getElementById('txtNomAl').value, cedRep: document.getElementById('txtCedRep').value, apRep: document.getElementById('txtApRep').value, nomRep: document.getElementById('txtNomRep').value, idestado: document.getElementById('txtEstado').value },
                dataType: "json",
                success: function (data) {

                    $('#example2').DataTable().destroy();

                    $('#example2').DataTable({
                        "autoWidth": false,
                        "info": false,
                        "JQueryUI": true,
                        "ordering": true,
                        "paging": true,
                        "scrollCollapse": true,
                        "responsive": true,
                        "processing": true,
                        "searching" : false,
                        "data": data.detsCargasLectivas,
                        "columns": [
                            { "data": "IdAlumno", "className": 'IdAlumno', "title": "Id Alumno" },
                            { "data": "Cedula", "className": 'Cedula', "title": "Cédula" },
                            //{ "data": "Nombres", "className": 'Nombres', "title": "Nombres" },
                            { "data": "Apellidos", "className": 'Apellidos', "title": "Apellidos" },
                            { "data": "Nombres", "className": 'Nombres', "title": "Nombres" },
                            { "data": "Estado", "className": 'Estado', "title": "Estado" },
                            {
                                "width": "10%","render": function (data, type, row) {

                                var myUrl = '@Url.Action("Edit", "Alumno")/' + row.IdAlumno;
                                return '<a href=\"' + myUrl + '\" class=\"btn btn-default btn-sm\">Editar</a>';
                            }
                            },
                        ],
                    });

                    //$('#txtSelectCurso, #txtSelectMateria, #txtSelectPeriodoLectivo').select2('disable');
                    //$('#txtSelectCurso, #txtSelectMateria, #txtSelectPeriodoLectivo').select2('enable');
                }
            });
        }

    }

