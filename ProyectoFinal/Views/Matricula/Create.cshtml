                                            </div>
                                        </div>
                                    </div>
                                    @*<div class="col-md-6">
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <label for="NNuCurso" class="control-label">Curso Anterior</label>
                                            </div>
                                            <div class="col-md-8">
                                                <input type="text" id="txtCurso" name="txtCurso" class="form-control" readonly />
                                            </div>
                                        </div>
                                    </div>*@
                                </div>

                                <br />

                            </div>

                        </div>

                    </div>

                    <div class="box-body">
                        <label for="NNuTonelaje" class="control-label">Oferta</label>
                        <div class="form-group">
                            <input type="text" id="txtSelectOferta" />
                            <input type="text" id="txtOferta" hidden />
