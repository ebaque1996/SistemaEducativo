                            </div>

                            <div class="box-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <label for="NNuPeriodo" class="control-label">Peíodo Lectivo</label>
