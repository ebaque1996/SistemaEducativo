<script type="text/javascript">
    $(document).ready(function () {
        $("#txtSelectAlumno").on("select2-selecting", function (e) { document.getElementById('txtAlumno').value = e.val; });

        $('#txtSelectAlumno').select2({
            width: '50%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Alumno",

            ajax: {
                url: '/Matricula/GetAlumnos',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

    });

    $('#txtSelectAlumno').on("change", function (e) {
        if ($(txtSelectAlumno).select2('data') != null) {
            $.ajax({
                type: "GET",
                url: "/Matricula/GetDetalleAlumno",
                data: { idAlu: document.getElementById('txtAlumno').value },
                dataType: "json",
                success: function (data) {
                    $("#txtNombre").val(data.data.Nombres);
                    $("#txtApellido").val(data.data.Apellidos);
                    $("#txtTelefono").val(data.data.Telefono);
                    $("#txtDireccion").val(data.data.Direccion);
                    $("#txtColegio").val(data.data.ColegioAnterior);
                }
            });
        } else {
            $("#txtNombre").val('');
            $("#txtApellido").val('');
            $("#txtTelefono").val('');
            $("#txtDireccion").val('');
            $("#txtColegio").val('');
        }

    });

    $(document).ready(function () {
        $("#txtSelectOferta").on("select2-selecting", function (e) { document.getElementById('txtOferta').value = e.val; });

        $('#txtSelectOferta').select2({
            width: '50%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Oferta",

            ajax: {
                url: '/Matricula/GetOfertas',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

    });

    $('#txtSelectOferta').on("change", function (e) {
        if ($(txtSelectOferta).select2('data') != null) {
            $.ajax({
                type: "GET",
                url: "/Matricula/GetDetalleOferta",
                data: { idOfer: document.getElementById('txtOferta').value },
                dataType: "json",
                success: function (data) {
                    console.log(data.data);
                    $("#txtPeriodo").val(data.data.DescPeriodo);
                    $("#txtCurso").val(data.data.DescCurso);
                    $("#txtParalelo").val(data.data.DescParalelo);
                    $("#txtProfesor").val(data.data.DescProfesor);
                    $("#txtDisponibles").val(data.data.DescDisponible);
                }
            });
        } else {
            $("#txtPeriodo").val('');
            $("#txtCurso").val('');
            $("#txtParalelo").val('');
            $("#txtProfesor").val('');
            $("#txtDisponibles").val('');            
        }

    });

    $('#btnGenerar').on('click', function () {
        var IdAlumno = document.getElementById("txtAlumno").value;
        var IdOferta = document.getElementById("txtOferta").value;
        var Estado = "A";

        //var chkestado = $('input[name="chkEstado"]').is(':checked')

        /*if (chkestado == false) {
            Estado = "I";
        }*/

        var previousWindowKeyDown = window.onkeydown;

        var jsonCad = "{'IdMatricula':'" + 0 + "'";
        jsonCad = jsonCad + ", 'IdAlumno': '" + IdAlumno + "'";
        jsonCad = jsonCad + ", 'IdOferta': '" + IdOferta + "'";
        jsonCad = jsonCad + ", 'Estado': '" + Estado + "'";
        jsonCad = jsonCad + "}";

        swal({
            title: "Matricula ",
            text: "Esta seguro que desea grabar los datos",
            type: "info",
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true
        }, function (isConfirm) {
            window.onkeydown = previousWindowKeyDown;
            if (isConfirm) {
                $.ajax(
                    {
                        type: "POST",
                        url: "/Matricula/Create",
                        data: jsonCad,
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (data) {

                            if (data.bResultado) {
                                swal("Saved", data.Message, "success");

                                window.setTimeout(function () {
                                    location.href = '@Url.Action("Create", "Matricula")';
                                }, 4000);

                            }
                            else {
                                swal("Cancelled", data.Message, "error");
                            }
                        }
                    }
                )
            }
        });
    });
</script>