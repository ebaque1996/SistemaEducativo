@model IEnumerable<ProyectoFinalModel.Matricula>

<p>
    @Html.ActionLink("Crear Matricula", "Create")
</p>

<div class="content">
    <div class="row">
        <div class="col-md-12">
            <table id="example2" class="table table-striped table-bordered dt-responsive nowrap">
                <thead>
                    <tr>
                        <th>Id Matricula</th>
                        <th>Id Alumno</th>
                        <th>Id Oferta</th>
                        <th>Alumno</th>
                        <th>Oferta</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#example2').DataTable().destroy();

        var arr = @Html.Raw(Json.Encode(Model));

        $('#example2').DataTable({
            "autoWidth": false,
            "info": false,
            //"serverSide": true,
            "JQueryUI": true,
            "ordering": true,
            "paging": true,
            //"scrollY": "500px",
            //"Select": true,
            "scrollCollapse": true,
            "responsive": true,
            "processing": true,
            //"data": data.data,
            "data": arr,
            "columns": [
                { "data": "IdMatricula", "className": 'IdMatricula', "title": "Id Matricula" },
                { "data": "IdAlumno", "className": 'IdAlumno', "title": "Id Alumno", "visible": false },
                { "data": "IdOferta", "className": 'IdOferta', "title": "Id Oferta", "visible": false },

                { "data": "DescAlumno", "className": 'DescAlumno', "title": "Alumno" },
                { "data": "DescOferta", "className": 'DescOferta', "title": "Oferta" },
                { "data": "Estado", "className": 'Estado', "title": "Estado" },
                {
                    "render": function (data, type, row) {

                    var myUrl = '@Url.Action("Edit", "Matricula")/' + row.IdMatricula;
                    return '<a href=\"' + myUrl + '\" class=\"btn btn-default btn-sm\">Edit</a>';
                }
                },
            ],
        });
    });

</script>