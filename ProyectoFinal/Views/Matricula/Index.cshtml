    $('#example2').DataTable().on('click', '.btnAnularRow', function () {
        var table = $('#example2').DataTable();
        var data = table.row($(this).parents('tr')).data();        
        var previousWindowKeyDown = window.onkeydown;

        var jsonCad = "{'IdMatricula':'" + data.IdMatricula + "'";
        jsonCad = jsonCad + "}";

        swal({
            title: "Matrícula ",
            text: "¿Esta seguro que desea anular la matrícula del estudiante " + data.DescAlumno + "?",
            type: "info",
            showCancelButton: true,
            closeOnConfirm: false,
            showLoaderOnConfirm: true
        },
            function (isConfirm) {
                window.onkeydown = previousWindowKeyDown;                

                if (isConfirm) {
                    
                    $.ajax(
                        {
                            type: "POST",
                            url: "/Matricula/AnularMatricula",
                            data: jsonCad,
                            contentType: "application/json; charset=utf-8",
                            dataType: "json",
                            success: function (data) {

                                if (data.bResultado) {
                                    swal("Saved", data.Message, "success");
                                    consultar();                               
                                }
                                else {
                                    swal("Cancelled", data.Message, "error");
                                }
                            }
                        }
                    )
                }
        });
    });

