<script>
    $(document).ready(function () {
        //$(document).ready(function () {
            $("#txtSelectProfesor").on("select2-selecting", function (e) { document.getElementById('txtProfesor').value = e.val; });
            $("#txtSelectCurso").on("select2-selecting", function (e) { document.getElementById('txtCurso').value = e.val; });
            $("#txtSelectPeriodo").on("select2-selecting", function (e) { document.getElementById('txtPeriodo').value = e.val; });
            $("#txtSelectMateria").on("select2-selecting", function (e) { document.getElementById('txtMateria').value = e.val; });
            $("#txtSelectEstado").on("select2-selecting", function (e) { document.getElementById('txtEstado').value = e.val; });

            $('#txtSelectProfesor').select2({
                width: '100%',
                allowClear: true,
                 minimumInputLength: 3,
                placeholder: "Profesor",

                ajax: {
                    url: '/CargaLectiva/GetProfesores',
                    dataType: 'json',

                    data: function (term, page) {
                        return {
                            q: term, view: "Index" // search term
                        };
                    },
                    results: function (data, page) { // parse the results into the format expected by Select2.
                        // since we are using custom formatting functions we do not need to alter the remote JSON data
                        return { results: data.items };
                    },
                    cache: true
                },
                dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
                escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
            });

            $('#txtSelectCurso').select2({
                width: '100%',
                allowClear: true,
                 minimumInputLength: 3,
                placeholder: "Curso",

                ajax: {
                    url: '/CargaLectiva/GetCursos',
                    dataType: 'json',

                    data: function (term, page) {
                        return {
                            q: term, view: "Index" // search term
                        };
                    },
                    results: function (data, page) { // parse the results into the format expected by Select2.
                        // since we are using custom formatting functions we do not need to alter the remote JSON data
                        return { results: data.items };
                    },
                    cache: true
                },
                dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
                escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
            });

            $('#txtSelectPeriodo').select2({
                width: '100%',
                allowClear: true,
                // minimumInputLength: 3,
                placeholder: "Periodo",

                ajax: {
                    url: '/CargaLectiva/GetPeriodos',
                    dataType: 'json',

                    data: function (term, page) {
                        return {
                            q: term, view: "Index" // search term
                        };
                    },
                    results: function (data, page) { // parse the results into the format expected by Select2.
                        // since we are using custom formatting functions we do not need to alter the remote JSON data
                        return { results: data.items };
                    },
                    cache: true
                },
                dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
                escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
            });

            $('#txtSelectMateria').select2({
                width: '100%',
                allowClear: true,
                // minimumInputLength: 3,
                placeholder: "Materia",

                ajax: {
                    url: '/CargaLectiva/GetMaterias',
                    dataType: 'json',

                    data: function (term, page) {
                        return {
                            q: term, view: "Index" // search term
                        };
                    },
                    results: function (data, page) { // parse the results into the format expected by Select2.
                        // since we are using custom formatting functions we do not need to alter the remote JSON data
                        return { results: data.items };
                    },
                    cache: true
                },
                dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
                escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
            });

            $('#txtSelectEstado').select2({
                width: '100%',
                allowClear: true,
                // minimumInputLength: 3,
                placeholder: "Estado",

                ajax: {
                    url: '/CargaLectiva/GetEstados',
                    dataType: 'json',

                    data: function (term, page) {
                        return {
                            q: term // search term
                        };
                    },
                    results: function (data, page) { // parse the results into the format expected by Select2.
                        // since we are using custom formatting functions we do not need to alter the remote JSON data
                        return { results: data.items };
                    },
                    cache: true
                },
                dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
                escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
            });

        //document.getElementById('txtMateria').value = null;
        //});
    });

    $('#txtSelectPeriodo').on("change", function (e) {
        if ($(txtSelectPeriodo).select2('data') == null) {
            document.getElementById('txtPeriodo').value = null;
        }
    });

    $('#txtSelectCurso').on("change", function (e) {
        if ($(txtSelectCurso).select2('data') == null) {
            document.getElementById('txtCurso').value = null;
        }
    });

    $('#txtSelectMateria').on("change", function (e) {
        if ($(txtSelectMateria).select2('data') == null) {
            document.getElementById('txtMateria').value = null;
        }
    });

    $('#txtSelectProfesor').on("change", function (e) {
        if ($(txtSelectProfesor).select2('data') == null) {
            document.getElementById('txtProfesor').value = null;
        }
    });

    $('#txtSelectEstado').on("change", function (e) {
        if ($(txtSelectEstado).select2('data') == null) {
            document.getElementById('txtEstado').value = null;
        }
    });

    $('#btnConsultar').on('click', function () { consultar(); });

    function consultar() {        

        if (true) {
            $.ajax({
                type: "GET",
                url: "/CargaLectiva/GetCargasLectivas",
                data: { idperiodo: document.getElementById('txtPeriodo').value, idoferta: document.getElementById('txtCurso').value, idmateria: document.getElementById('txtMateria').value, idprofesor: document.getElementById('txtProfesor').value, idestado: document.getElementById('txtEstado').value },
                dataType: "json",
                success: function (data) {

                    $('#example2').DataTable().destroy();

                    $('#example2').DataTable({
                        "autoWidth": false,
                        "info": false,
                        "JQueryUI": true,
                        "ordering": true,
                        "paging": true,
                        "scrollCollapse": true,
                        "responsive": true,
                        "processing": true,
                        "searching" : false,
                        "data": data.detsCargasLectivas,
                        //"drawCallback": function (settings) {
                        //    var api = this.api();
                        //    var rows = api.rows({ page: 'current' }).nodes();
                        //    var last = null;
                        //    api.column(5, { page: 'current' }).data().each(function (group, i) {
                        //        if (last !== group) {
                        //            $(rows).eq(i).before('' + group + ''); last = group;
                        //        }
                        //    });
                        //},
                        "columns": [
                            { "data": "IdCargaLectiva", "className": 'IdCargaLectiva', "title": "Id Carga Lectiva" },
                            { "data": "IdProfesor", "className": 'IdProfesor', "title": "Id Profesor", "visible": false },
                            //{ "data": "IdCurso", "className": 'IdCurso', "title": "Id Curso", "visible": false },
                            { "data": "IdOferta", "className": 'IdOferta', "title": "Id Curso", "visible": false },
                            { "data": "IdPeriodoLectivo", "className": 'IdPeriodoLectivo', "title": "Id Periodo Lectivo", "visible": false },
                            { "data": "IdMateria", "className": 'IdMateria', "title": "Id Materia", "visible": false },
                            //{ "data": "DescCurso", "className": 'DescCurso', "title": "Curso" },
                            { "data": "DescOferta", "className": 'DescOferta', "title": "Curso" },
                            { "data": "DescMateria", "className": 'DescMateria', "title": "Materia" },
                            { "data": "DescPerLec", "className": 'DescPerLec', "title": "Periodo" },
                            { "data": "DescProfesor", "className": 'DescProfesor', "title": "Profesor" },
                            { "data": "Estado", "className": 'Estado', "title": "Estado" },
                            {
                                "width": "10%","render": function (data, type, row) {

                                var myUrl = '@Url.Action("Edit", "CargaLectiva")/' + row.IdCargaLectiva;
                                return '<a href=\"' + myUrl + '\" class=\"btn btn-default btn-sm\">Edit</a>';
                            }
                            },
                        ],
                    });

                    //$('#txtSelectCurso, #txtSelectMateria, #txtSelectPeriodoLectivo').select2('disable');
                    //$('#txtSelectCurso, #txtSelectMateria, #txtSelectPeriodoLectivo').select2('enable');
                }
            });
        }
        
    }

</script>

