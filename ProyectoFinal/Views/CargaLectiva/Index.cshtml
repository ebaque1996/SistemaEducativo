<div class="content">

    <div class="row">
        <div class="box box-default">
            <div class="box-header with-border">
                <h3 class="box-title"> Parametros de Consulta </h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" id="txtSelectPeriodo" />
                            <input type="text" id="txtPeriodo" hidden />
                        </div>
                    </div>
                    @*</div>
            <div class="row">*@
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" id="txtSelectCurso" />
                            <input type="text" id="txtCurso" hidden />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" id="txtSelectMateria" />
                            <input type="text" id="txtMateria" hidden />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" id="txtSelectProfesor" />
                            <input type="text" id="txtProfesor" hidden />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="text" id="txtSelectEstado" />
                            <input type="text" id="txtEstado" hidden />
                        </div>
                    </div>                   
                </div>

            </div>
            <div class="box-footer with-border">
                <input type="button" class="btn btn-primary" id="btnConsultar" value="Consultar" />
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <table id="example2" class="table table-striped table-bordered dt-responsive nowrap">
                <thead>
                    <tr>
                        <th>Id Carga Lectiva</th>
                        <th>Id Profesor</th>
                        <th>Id Curso</th>
                        <th>Id Periodo Lectivo</th>
                        <th>Id Materia</th>
                        <th>Profesor</th>
                        <th>Curso</th>
                        <th>Periodo Lectivo</th>
                        <th>Materia</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@*<script src="https://cdn.datatables.net/rowgroup/1.1.1/js/dataTables.rowGroup.min.js"></script>*@
