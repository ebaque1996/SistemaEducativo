@if (!Request.IsAuthenticated)
{
    Response.Redirect("~/Account/Login");
}

<h2>Matriz de Calificaciones</h2>

<div class="content">
    <div class="row">
        <div class="box box-default">
            <div class="box-header with-border">
                <h3 class="box-title"> Parámetros de Consulta </h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label for="Periodo" class="control-label">Periodo:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" id="txtSelectPeriodo" />
                                <input type="text" id="txtPeriodo" hidden />
                                <input type="text" id="txtIdPeriodo" name="txtIdPeriodo" hidden />
                            </div>
                        </div>
                    </div>
                </div>

                <br />

                @*<div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <div class="col-md-4">
                                    <label for="Periodo" class="control-label">Tipo Reporte:</label>
                                </div>
                                <div class="col-md-8">
                                    <input type="text" id="txtSelectTipoReporte" />
                                    <input type="text" id="txtTipoReporte" hidden />
                                </div>
                            </div>
                        </div>
                    </div>

                    <br />*@

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="col-md-4">
                                <label for="Periodo" class="control-label">Curso:</label>
                            </div>
                            <div class="col-md-8">
                                <input type="text" id="txtSelectOferta" disabled />
                                <input type="text" id="txtOferta" hidden />
                            </div>
                        </div>
                    </div>
                </div>

                <br />

                @using (Html.BeginForm("PrintMatrizCalificaciones", "Reportes", FormMethod.Get, null))
                {
                    @*<input type="text" id="txtIdPeriodo" name="txtIdPeriodo" hidden />*@
                    <input type="text" id="txtIdOferta" name="txtIdOferta" hidden />
                    <button class="btn btn-primary" type="submit" id="btnConsultar">
                        <i class="fa fa-file-pdf-o"></i>
                    </button>
                }

            </div>
        </div>
    </div>



</div>

<script>
    $(document).ready(function () {

        document.getElementById("btnConsultar").disabled = true;

        $("#txtSelectPeriodo").on("select2-selecting", function (e) { document.getElementById('txtPeriodo').value = e.val; });
        $("#txtSelectPeriodo").on("select2-selecting", function (e) { document.getElementById('txtIdPeriodo').value = e.val; });

        $("#txtSelectOferta").on("select2-selecting", function (e) { document.getElementById('txtOferta').value = e.val; });
        $("#txtSelectOferta").on("select2-selecting", function (e) { document.getElementById('txtIdOferta').value = e.val; });

        $('#txtSelectPeriodo').on("change", function (e) {

            habilitarBoton();

            if (e.val == "") {
                $("#txtSelectPeriodo").select2("val", "");
                document.getElementById('txtPeriodo').value = null;
                document.getElementById('txtIdPeriodo').value = null;

                $("#txtSelectOferta").select2("val", "");
                document.getElementById('txtOferta').value = null;
                document.getElementById('txtIdOferta').value = null;

                $('#txtSelectOferta').select2('disable');
            } else {
                $('#txtSelectOferta').select2('enable');
            }
        });

        $('#txtSelectOferta').on("change", function (e) {

            habilitarBoton();

            if (e.val == "") {
                $("#txtSelectOferta").select2("val", "");
                document.getElementById('txtOferta').value = null;
                document.getElementById('txtIdOferta').value = null;
            }
        });

        $('#txtSelectPeriodo').select2({
            width: '100%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Periodo Lectivo",

            ajax: {
                url: '/Reportes/GetPeriodosLib',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

        $('#txtSelectOferta').select2({
            width: '100%',
            allowClear: true,
            // minimumInputLength: 3,
            placeholder: "Curso",

            ajax: {
                url: '/Reportes/GetOfertasLib',
                dataType: 'json',

                data: function (term, page) {
                    return {
                        q: term, IdPeriodoLectivo: document.getElementById('txtPeriodo').value // search term
                    };
                },
                results: function (data, page) { // parse the results into the format expected by Select2.
                    // since we are using custom formatting functions we do not need to alter the remote JSON data
                    return { results: data.items };
                },
                cache: true
            },
            dropdownCssClass: "bigdrop", // apply css that makes the dropdown taller
            escapeMarkup: function (m) { return m; } // we do not want to escape markup since we are displaying html in results
        });

        function habilitarBoton() {
            if ($(txtSelectOferta).select2('data') == null || $(txtSelectPeriodo).select2('data') == null) {
                document.getElementById("btnConsultar").disabled = true;
            } else {
                document.getElementById("btnConsultar").disabled = false;
            }
        }

    });
</script>
