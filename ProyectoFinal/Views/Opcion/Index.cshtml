    //                {
    //                    type: "POST",
    //                    url: "/Opcion/DeleteOpcion",
    //                    data: jsonCad,
    //                    contentType: "application/json; charset=utf-8",
    //                    dataType: "json",
    //                    success: function (data) {

    //                        if (data.bResultado) {
