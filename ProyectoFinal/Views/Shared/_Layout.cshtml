<!-- ADD THE CLASS fixed TO GET A FIXED HEADER AND SIDEBAR LAYOUT -->
<!-- the fixed layout is not compatible with sidebar-mini -->
<body class="hold-transition skin-blue fixed sidebar-mini">
    <script type="text/javascript">
        var modal, loading;
        function ShowProgress() {
            modal = document.createElement("DIV");
            modal.className = "modal";
            document.body.appendChild(modal);
            loading = document.getElementsByClassName("loading")[0];

            var top = Math.max(window.innerHeight / 2 - loading.offsetHeight / 2, 0);
            var left = Math.max(window.innerWidth / 2 - loading.offsetWidth / 2, 0);
            loading.style.top = top + "px";
            loading.style.left = left + "px";
        };
        ShowProgress();
    </script>

    <script type="text/javascript">
        function Splash() {
            var sCadHtml = '<div class="sk-folding-cube"> ' +
                '<div class="sk-cube1 sk-cube" > ' +
                '</div><div class="sk-cube2 sk-cube"> </div><div class="sk-cube4 sk-cube"></div><div class="sk-cube3 sk-cube"></div></div>';

            // var sCadHtml = '<div class="loading" align="center"> Loading.Please wait.< br /> <br /> <img src="/Content/Img/plapasa.jpg" alt="" /> </div >'
            var sCadHtmlIMg = '<img src="/Content/Img/Loading.gif" alt="animated"/>';


            var splash = window.pleaseWait({
                //logo: "/Content/Img/logo.jpg",
                //logo: "/Content/Img/loading1.gif",
                backgroundColor: '#0053A0',
                loadingHtml: "<h1 class='loading-message'>  </h1>" + sCadHtmlIMg
                //loadingHtml: "<h1 class='loading-message'>Plapasa S.A. </h1>" + sCadHtml
            });
            return splash;
        }

        waiter = Splash();
        $(document)
            .ready(function () {
                setTimeout(function () {
                    waiter.finish();
                }, 1000);
            });
    </script>



    <!-- Site wrapper -->
    <div class="wrapper">
        <header class="main-header" style="background-color: #0053A0">
            <!-- Logo -->
            <a href="#" class="logo" style="background-color: #0053A0">
                <!-- mini logo for sidebar mini 50x50 pixels -->
                <span class="logo-mini" style="background-color: #0053A0; width: 50px; height: 50px;">
                    @*<img style="width: 50px; height: 50px;" src="~/Content/Img/plapasa.jpg">*@
                </span>
                <!-- logo for regular state and mobile devices -->
                <span class="logo-lg" style="background-color: #0053A0">
                    @*<img style="width: 50px; height: 50px;" src="~/Content/Img/plapasa.jpg">*@
                </span>
            </a>
            <!-- Header Navbar: style can be found in header.less -->
            <nav class="navbar navbar-static-top" style="background-color: #0053A0">
                <!-- Sidebar toggle button-->
                <a href="#" class="sidebar-toggle" data-toggle="offcanvas" role="button">
                    <span class="sr-only">Toggle navigation</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </a>
                <div class="navbar-custom-menu">
