                        @Html.Partial("Profile")

                    </ul>
                </div>
            </nav>
        </header>
        <!-- =============================================== -->
        <aside class="main-sidebar">
            @*@Html.Partial("Menus")*@
            @*@Html.Partial("Menus", new ProyectoFinalModel.ProyectoFinalEntities().RolOpcion.Where(x => x.IdRol == Convert.ToInt32(Request.Cookies["Rol"].Value.ToString())).ToList());*@
            @{ 
